      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(dating_bot_handler_duration_seconds_bucket[5m])) by (le, handler))", "refId": "A", "legendFormat": "{{handler}}" }
      ]
    },
    {
